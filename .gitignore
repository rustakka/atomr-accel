# Cargo build artifacts
/target/
**/target/

# Cargo lockfile is committed at the workspace root only
# (it's already there; sub-crate Cargo.locks shouldn't be).
**/*/Cargo.lock

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Local environment overrides
.env
.envrc
.direnv/

# Criterion bench output
**/criterion/

# Profiler output
flamegraph.svg
perf.data*

# Claude harness worktrees
.claude/worktrees/

# Python virtualenvs / build artifacts (already partially ignored elsewhere)
.venv/
__pycache__/
dist/
*.egg-info/
.pytest_cache/

# Maturin compiled extension modules — built into python/<pkg>/ by
# `maturin develop`; the source of truth is in src/, not committed.
**/python/atomr_accel/_native*.so
**/python/atomr_accel/_native*.pyd
